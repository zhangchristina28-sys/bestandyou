---
import { nav, site } from '@/data/site';
---

<footer class="border-t border-oat bg-white/45">
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-10 md:grid-cols-[1.2fr_1fr]">
    <div>
      <p class="font-serif text-2xl">{site.name}</p>
      <p class="mt-3 max-w-md text-sm leading-6 text-ink/70">{site.description} Cosmetic information only; not medical advice.</p>
    </div>
    <nav class="grid grid-cols-2 gap-3 text-sm text-ink/75" aria-label="Footer navigation">
      {nav.map((item) => <a class="hover:text-moss" href={item.href}>{item.label}</a>)}
    </nav>
  </div>
</footer>
