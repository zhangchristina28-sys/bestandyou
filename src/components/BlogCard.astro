---
interface Props {
  title: string;
  description: string;
  href: string;
}
const { title, description, href } = Astro.props;
---

<article class="rounded-lg border border-oat bg-white p-5 shadow-soft">
  <h2 class="font-serif text-2xl leading-tight"><a class="hover:text-moss" href={href}>{title}</a></h2>
  <p class="mt-3 text-sm leading-6 text-ink/70">{description}</p>
  <a class="mt-4 inline-flex text-sm font-semibold text-moss hover:text-clay" href={href}>Read article</a>
</article>
