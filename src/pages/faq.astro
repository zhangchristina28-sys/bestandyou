---
import Layout from '@/components/Layout.astro';
import WaitlistForm from '@/components/WaitlistForm.astro';

const faqs = [
  ['What is scalp serum?', 'A scalp serum is a leave-on cosmetic product designed to be applied directly to the scalp. It can support a cleaner-feeling, more intentional scalp care routine depending on the formula.'],
  ['Is scalp serum good for oily scalp?', 'A lightweight, non-greasy scalp serum may be a good fit for oily scalp routines when it absorbs easily and does not coat the roots. Results and comfort vary by person.'],
  ['How often should I use scalp serum?', 'Many scalp serums are designed for regular or daily use, but the best frequency depends on the formula and your scalp comfort. Start slowly when trying a new leave-on product.'],
  ['Can I use it with shampoo bar?', 'Yes, a scalp serum can be used alongside a shampoo bar as separate steps: cleanse first, then apply a light leave-on product after washing or between wash days.'],
  ['Is this product for hair growth?', 'No. Root & Ritual is focused on cosmetic scalp care for oily and greasy-prone roots. It is not positioned as a hair growth treatment or medical product.'],
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(([q, a]) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a },
  })),
};
---

<Layout title="Scalp Care FAQ" description="Answers to common scalp serum and oily scalp care questions, with careful cosmetic guidance and no medical claims." schema={schema}>
  <section class="mx-auto max-w-4xl px-4 py-16">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-moss">FAQ</p>
    <h1 class="mt-4 font-serif text-5xl">Scalp care questions</h1>
    <div class="mt-10 space-y-4">
      {faqs.map(([q, a]) => (
        <details class="rounded-lg border border-oat bg-white p-5 shadow-soft">
          <summary class="cursor-pointer font-serif text-2xl">{q}</summary>
          <p class="mt-3 text-sm leading-6 text-ink/70">{a}</p>
        </details>
      ))}
    </div>
    <div class="mt-10"><WaitlistForm /></div>
  </section>
</Layout>
