---
import Layout from '@/components/Layout.astro';
import WaitlistForm from '@/components/WaitlistForm.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Oily Scalp Care Serum',
  brand: { '@type': 'Brand', name: 'Root & Ritual' },
  description: 'A lightweight, non-greasy daily scalp serum concept for oily and greasy-prone scalps.',
  category: 'Scalp care',
  offers: { '@type': 'Offer', availability: 'https://schema.org/PreOrder', priceCurrency: 'USD', price: '0' },
};
---

<Layout title="Oily Scalp Care Serum" description="Meet a lightweight, non-greasy daily scalp serum concept for oily and greasy-prone roots, featuring rosemary, tea tree, niacinamide, and aloe vera." schema={schema}>
  <section class="mx-auto grid max-w-6xl gap-10 px-4 py-16 md:grid-cols-[1fr_0.9fr] md:items-center">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-moss">Product concept</p>
      <h1 class="mt-4 font-serif text-5xl leading-tight md:text-6xl">Oily Scalp Care Serum</h1>
      <p class="mt-5 text-lg leading-8 text-ink/72">A lightweight, non-greasy daily scalp care concept for women whose roots feel oily quickly, look flat by the next day, or need a fresh routine between washes.</p>
      <div class="mt-7 flex flex-wrap gap-3">
        <a class="rounded-full bg-ink px-6 py-3 text-sm font-semibold text-white hover:bg-moss" href="#waitlist">Join the Waitlist</a>
        <a class="rounded-full border border-moss px-6 py-3 text-sm font-semibold text-moss hover:bg-white" href="/scalp-quiz">Take the Scalp Quiz</a>
      </div>
    </div>
    <img src="/og-scalp-care.svg" alt="Natural scalp care serum botanical visual" class="rounded-lg border border-oat bg-white shadow-soft" />
  </section>

  <section class="border-y border-oat bg-white/50">
    <div class="mx-auto grid max-w-6xl gap-8 px-4 py-14 md:grid-cols-3">
      <div><h2 class="font-serif text-2xl">Best for</h2><p class="mt-3 text-sm leading-6 text-ink/70">Oily scalps, greasy-prone roots, frequent dry shampoo users, and routines that need a clean-feeling leave-on step.</p></div>
      <div><h2 class="font-serif text-2xl">Use moments</h2><p class="mt-3 text-sm leading-6 text-ink/70">After washing, before styling, at night, or on non-wash days when the scalp needs a light refresh.</p></div>
      <div><h2 class="font-serif text-2xl">Texture</h2><p class="mt-3 text-sm leading-6 text-ink/70">Lightweight, non-greasy, fast-spreading, and designed for daily scalp care without a coated feel.</p></div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16">
    <div class="grid gap-10 md:grid-cols-[0.8fr_1.2fr]">
      <div>
        <h2 class="font-serif text-4xl">Formula direction</h2>
        <p class="mt-4 leading-7 text-ink/72">The first product direction is cosmetic, gentle, and practical. It is not positioned as a treatment for hair loss, seborrheic dermatitis, or any scalp disease.</p>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        {['Rosemary for a fresh botanical feel', 'Tea tree for a clean sensory profile', 'Niacinamide for modern scalp care', 'Aloe vera for a light water-rich base'].map((item) => (
          <div class="rounded-lg border border-oat bg-white p-5"><p class="font-semibold">{item}</p></div>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-4xl px-4 pb-16">
    <WaitlistForm />
  </section>
</Layout>
