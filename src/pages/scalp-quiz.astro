---
import Layout from '@/components/Layout.astro';
import WaitlistForm from '@/components/WaitlistForm.astro';

const questions = [
  { question: 'How often does your scalp feel oily?', answers: ['Every day', 'Every 2-3 days', 'Only sometimes'] },
  { question: 'Do your roots look greasy within 24 hours?', answers: ['Yes', 'Sometimes', 'Rarely'] },
  { question: 'Do you use dry shampoo often?', answers: ['Most weeks', 'Occasionally', 'Almost never'] },
  { question: 'Is your scalp sensitive?', answers: ['Yes', 'A little', 'No'] },
];
---

<Layout title="Scalp Quiz for Oily Roots" description="Take a simple oily scalp quiz to understand your greasy-prone roots and join the natural scalp care waitlist.">
  <section class="mx-auto max-w-4xl px-4 py-16">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-moss">Scalp quiz</p>
    <h1 class="mt-4 font-serif text-5xl">How oily does your scalp feel?</h1>
    <p class="mt-5 text-lg leading-8 text-ink/72">This quick static quiz helps you reflect on your routine. It is not a diagnosis and does not replace medical advice.</p>
    <div class="mt-10 space-y-5">
      {questions.map(({ question, answers }) => (
        <fieldset class="rounded-lg border border-oat bg-white p-5 shadow-soft">
          <legend class="font-serif text-2xl">{question}</legend>
          <div class="mt-4 grid gap-3 sm:grid-cols-3">
            {answers.map((answer) => (
              <label class="flex min-h-12 items-center gap-2 rounded-md border border-oat bg-linen px-4 text-sm">
                <input type="radio" name={question} />
                {answer}
              </label>
            ))}
          </div>
        </fieldset>
      ))}
    </div>
    <div class="mt-10">
      <WaitlistForm />
    </div>
  </section>
</Layout>
